FROM python:3.13-slim

WORKDIR /app

COPY requirements-a2a.txt .
RUN pip install --no-cache-dir -r requirements-a2a.txt

COPY shared/ shared/
COPY preop_agent/ preop_agent/
COPY postop_agent/ postop_agent/
COPY src/ src/

ENV PORT=8080
ENV AGENT_MODULE=postop_agent.app:a2a_app
ENV GOOGLE_GENAI_USE_VERTEXAI=FALSE

CMD uvicorn ${AGENT_MODULE} --host 0.0.0.0 --port ${PORT}
